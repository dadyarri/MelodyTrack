@page "/calendar"
@using MelodyTrack.Web.Client.Models

<PageTitle>Календарь | MelodyTrack</PageTitle>
<RadzenRow Gap="5" RowGap="5">
    <RadzenColumn Size="12">
        <RadzenText TextStyle="TextStyle.H2">Календарь</RadzenText>

        <RadzenScheduler @ref="@scheduler" SlotRender="@OnSlotRender" style="height: 768px;" TItem="Appointment"
                         Data="@appointments" StartProperty="StartTime" EndProperty="EndTime"
                         TextProperty="Service"
                         SlotSelect="@OnSlotSelect" AppointmentSelect="@OnAppointmentSelect"
                         AppointmentRender="@OnAppointmentRender"
                         AppointmentMove="@OnAppointmentMove">
            <RadzenDayView/>
            <RadzenWeekView/>
            <RadzenMonthView/>
        </RadzenScheduler>
    </RadzenColumn>
</RadzenRow>

